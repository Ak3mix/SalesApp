{
	"appId": "com.tuapp.ejemplo",
	"appName": "VentasPro",
	"webDir": "dist",
	"bundledWebRuntime": false,
	"android": {
		"compileOptions": {
			"sourceCompatibility": 17,
			"targetCompatibility": 17
		},
		"kotlinOptions": {
			"jvmTarget": "17"
		}
	},
	"plugins": {
		"StatusBar": {
			"style": "DARK",
			"overlaysWebView": false
		},
		"NavigationBar": {
			"style": "LIGHT",
			"overridesWebView": false
		},
		"Camera": {
			"saveToGallery": false,
			"allowEditing": false,
			"quality": 80,
			"sourceType": [
				"camera",
				"photos"
			]
		}
	}
}
